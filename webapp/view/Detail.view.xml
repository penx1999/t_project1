<mvc:View
    controllerName="t_project1.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    displayBlock="true">

    <Page
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiNoContentPadding">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" press=".onNavBack"/>
                </contentLeft>
                <contentMiddle>
                    <Title text="{detailModel>/productAllocationObject}" level="H4"/>
                </contentMiddle>
            </Bar>
        </customHeader>

        <content>

            <!-- Object Header -->
            <ObjectHeader
                title="{detailModel>/productAllocationObject}"
                titleLevel="H2"
                backgroundDesign="Translucent"
                class="sapUiSmallMarginBottom">
            </ObjectHeader>

            <!-- Selection Range Panel -->
            <Panel
                headerText="{i18n>selectionRange}"
                expandable="false"
                expanded="true"
                class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                <content>
                    <HBox alignItems="Center" class="sapUiSmallMargin">
                        <DatePicker
                            id="idDateFrom"
                            value="{
                                path: 'detailModel>/fec_ini',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            change=".onDateChange"
                            width="140px"/>
                        <Text text=" – " class="sapUiSmallMarginBeginEnd"/>
                        <DatePicker
                            id="idDateTo"
                            value="{
                                path: 'detailModel>/fec_fin',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: { pattern: 'dd/MM/yyyy' }
                            }"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            change=".onDateChange"
                            width="140px"/>
                    </HBox>
                </content>
            </Panel>

            <!-- Dynamic Data Table -->
            <Panel
                headerText="{detailModel>/tableTitle}"
                expandable="false"
                expanded="true"
                class="sapUiSmallMarginBeginEnd">
                <content>
                    <t:Table
                        id="idDynamicTable"
                        noData="{i18n>noDataText}"
                        busy="{detailModel>/busy}"
                        busyIndicatorDelay="0"
                        alternateRowColors="true"
                        visibleRowCountMode="Auto"
                        minAutoRowCount="5"
                        selectionMode="None"
                        navigationMode="Scrollbar"
                        columnHeaderHeight="32"
                        rowHeight="32"
                        width="100%"
                        class="sapUiSmallMarginBottom">
                        <t:columns/>
                    </t:Table>
                </content>
            </Panel>

        </content>
    </Page>
</mvc:View>
