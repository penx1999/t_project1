<mvc:View
    controllerName="t_project1.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    displayBlock="true">

    <Page
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiNoContentPadding">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" press=".onNavBack"/>
                </contentLeft>
                <contentMiddle>
                    <Title text="{detailModel>/productAllocationObject}" level="H4"/>
                </contentMiddle>
                <contentRight>
                    <Button
                        id="idSaveButton"
                        text="{i18n>saveButton}"
                        type="Emphasized"
                        icon="sap-icon://save"
                        press=".onSave"
                        enabled="{detailModel>/hasChanges}"/>
                </contentRight>
            </Bar>
        </customHeader>

        <content>

            <!-- Object Header -->
            <ObjectHeader
                title="{detailModel>/productAllocationObject}"
                titleLevel="H2"
                backgroundDesign="Translucent">
            </ObjectHeader>

            <!-- Selection Range Panel -->
            <Panel
                headerText="{i18n>selectionRange}"
                expandable="false"
                expanded="true"
                width="100%">
                <content>
                    <HBox alignItems="Center" class="sapUiSmallMargin">
                        <DatePicker
                            id="idDateFrom"
                            value="{detailModel>/fec_ini}"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            change=".onDateChange"
                            width="140px"/>
                        <Text text=" – " class="sapUiSmallMarginBeginEnd"/>
                        <DatePicker
                            id="idDateTo"
                            value="{detailModel>/fec_fin}"
                            displayFormat="dd/MM/yyyy"
                            valueFormat="dd/MM/yyyy"
                            change=".onDateChange"
                            width="140px"/>
                    </HBox>
                </content>
            </Panel>

            <!-- Dynamic Data Table -->
            <Panel
                headerText="{detailModel>/tableTitle}"
                expandable="false"
                expanded="true"
                width="100%">
                <content>
                    <t:Table
                        id="idDynamicTable"
                        noData="{i18n>noDataText}"
                        busy="{detailModel>/busy}"
                        busyIndicatorDelay="0"
                        alternateRowColors="true"
                        visibleRowCountMode="Fixed"
                        visibleRowCount="{detailModel>/rowCount}"
                        selectionMode="None"
                        columnHeaderHeight="32"
                        width="100%"
                        class="sapUiSmallMarginBottom">
                        <t:extension>
                            <OverflowToolbar>
                                <ToolbarSpacer/>
                                <Button
                                    id="idNewRowButton"
                                    text="{i18n>newButton}"
                                    icon="sap-icon://add"
                                    type="Transparent"
                                    press=".onAddNewRow"/>
                            </OverflowToolbar>
                        </t:extension>
                        <t:columns/>
                    </t:Table>
                </content>
            </Panel>

        </content>
    </Page>
</mvc:View>
