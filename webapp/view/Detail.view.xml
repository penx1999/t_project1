<mvc:View
    controllerName="t_project1.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page
        title="{i18n>detailTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <content>
            <VBox class="sapUiMediumMargin">

                <Title text="{detailModel>/productAllocationObject}" level="H3" class="sapUiSmallMarginBottom"/>

                <Table
                    id="idDynamicTable"
                    noDataText="{i18n>noDataText}"
                    growing="true"
                    growingThreshold="50"
                    busy="{detailModel>/busy}"
                    sticky="ColumnHeaders">
                    <columns/>
                    <items/>
                </Table>

            </VBox>
        </content>
    </Page>
</mvc:View>
