<mvc:View
    controllerName="t_project1.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    displayBlock="true">

    <Page
        showNavButton="true"
        navButtonPress=".onNavBack"
        class="sapUiNoContentPadding">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" press=".onNavBack"/>
                </contentLeft>
                <contentMiddle>
                    <Title text="{detailModel>/productAllocationObject}" level="H4"/>
                </contentMiddle>
                <contentRight>
                    <Button
                        id="idEditButton"
                        text="Edit"
                        type="Emphasized"
                        icon="sap-icon://edit"
                        visible="{= ${detailModel>/editMode} !== true }"
                        press=".onEdit"/>
                    <Button
                        id="idCancelButton"
                        text="{i18n>cancelButton}"
                        type="Default"
                        icon="sap-icon://decline"
                        enabled="{detailModel>/hasChanges}"
                        press=".onCancel"/>
                    <Button
                        id="idSaveButton"
                        text="{i18n>saveButton}"
                        type="Emphasized"
                        icon="sap-icon://save"
                        press=".onSave"
                        enabled="{detailModel>/hasChanges}"/>
                </contentRight>
            </Bar>
        </customHeader>

        <content>

            <!-- Object Header -->
            <ObjectHeader
                title="{detailModel>/productAllocationObject}"
                titleLevel="H2"
                backgroundDesign="Translucent">
            </ObjectHeader>

            <!-- Service Message Strip -->
            <MessageStrip
                id="idServiceMessage"
                text="{detailModel>/messageText}"
                type="{detailModel>/messageType}"
                visible="{detailModel>/messageVisible}"
                showCloseButton="true"
                class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"
                close=".onMessageClose"/>

            <!-- Selection Range Panel -->
            <Panel
                headerText=" "
                expandable="false"
                expanded="true"
                width="100%">
                <content>
                    <VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd">
                        <HBox alignItems="End" class="sapUiTinyMarginTop sapUiSmallMarginBottom">
                            <VBox width="310px" class="sapUiSmallMarginEnd zqFilterFrame">
                                <Label text="{i18n>selectionRange}" width="100%"/>
                                <HBox alignItems="Center" width="100%" class="sapUiTinyMarginTop">
                                    <DatePicker
                                        id="idDateFrom"
                                        value="{detailModel>/fec_ini}"
                                        displayFormat="dd/MM/yyyy"
                                        valueFormat="dd/MM/yyyy"
                                        change=".onDateChange"
                                        enabled="true"
                                        width="135px"/>
                                    <Text text=" – " class="sapUiTinyMarginBeginEnd"/>
                                    <DatePicker
                                        id="idDateTo"
                                        value="{detailModel>/fec_fin}"
                                        displayFormat="dd/MM/yyyy"
                                        valueFormat="dd/MM/yyyy"
                                        change=".onDateChange"
                                        enabled="true"
                                        width="135px"/>
                                </HBox>
                            </VBox>
                            <VBox width="230px" class="sapUiSmallMarginEnd zqFilterFrame">
                                <Label text="{i18n>allocationObjectLabel}" width="100%"/>
                                <Input
                                    id="idAllocationObjectFilter"
                                    value="{detailModel>/allocationObjectFilter}"
                                    change=".onAllocationObjectChange"
                                    class="sapUiTinyMarginTop"
                                    width="100%"/>
                            </VBox>
                            <VBox width="160px" class="sapUiSmallMarginEnd zqFilterFrame">
                                <Label text="{i18n>materialLabel}" width="100%"/>
                                <Input
                                    id="idMaterialFilter"
                                    value="{detailModel>/materialFilter}"
                                    change=".onMaterialFilterChange"
                                    class="sapUiTinyMarginTop"
                                    width="100%"/>
                            </VBox>
                            <VBox width="160px" class="zqFilterFrame">
                                <Label text="{i18n>plantLabel}" width="100%"/>
                                <Input
                                    id="idPlantFilter"
                                    value="{detailModel>/plantFilter}"
                                    change=".onPlantFilterChange"
                                    class="sapUiTinyMarginTop"
                                    width="100%"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
            </Panel>

            <!-- Dynamic Data Table -->
            <Panel
                headerText="{detailModel>/tableTitle}"
                expandable="false"
                expanded="true"
                width="100%">
                <content>
                    <t:Table
                        id="idDynamicTable"
                        noData="{i18n>noDataText}"
                        busy="{detailModel>/busy}"
                        busyIndicatorDelay="0"
                        alternateRowColors="true"
                        visibleRowCountMode="Fixed"
                        visibleRowCount="{detailModel>/rowCount}"
                        selectionMode="{= ${detailModel>/editMode} ? 'MultiToggle' : 'None' }"
                        columnHeaderHeight="32"
                        width="100%"
                        class="sapUiSmallMarginBottom">
                        <t:extension>
                            <OverflowToolbar>
                                <ToolbarSpacer/>
                                <Button
                                    id="idNewRowButton"
                                    text="{i18n>newButton}"
                                    icon="sap-icon://add"
                                    type="Transparent"
                                    enabled="{detailModel>/editMode}"
                                    press=".onAddNewRow"/>
                                <Button
                                    id="idDeleteRowButton"
                                    text="{i18n>deleteButton}"
                                    icon="sap-icon://delete"
                                    type="Transparent"
                                    enabled="{detailModel>/editMode}"
                                    press=".onDeleteRows"/>
                                <Button
                                    id="idCopyRowButton"
                                    text="{i18n>copyButton}"
                                    icon="sap-icon://copy"
                                    type="Transparent"
                                    enabled="{detailModel>/editMode}"
                                    press=".onCopyRow"/>
                                <Button
                                    id="idChangeStatusButton"
                                    text="{i18n>changeStatusButton}"
                                    type="Transparent"
                                    enabled="{detailModel>/editMode}"
                                    press=".onOpenChangeStatusMenu"/>
                                <Button
                                    id="idChangeConstraintStatusButton"
                                    text="{i18n>changeConstraintStatusButton}"
                                    type="Transparent"
                                    enabled="{detailModel>/editMode}"
                                    press=".onOpenChangeConstraintStatusMenu"/>
                                <Button
                                    id="idDownloadButton"
                                    icon="sap-icon://download"
                                    type="Transparent"
                                    tooltip="Download"
                                    press=".onDownload"/>
                                <Button
                                    id="idUploadButton"
                                    icon="sap-icon://upload"
                                    type="Transparent"
                                    tooltip="Upload"
                                    enabled="{detailModel>/editMode}"
                                    press=".onUpload"/>
                            </OverflowToolbar>
                        </t:extension>
                        <t:columns/>
                    </t:Table>
                </content>
            </Panel>

        </content>
    </Page>
</mvc:View>
